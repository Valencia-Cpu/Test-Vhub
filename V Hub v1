local PlayerCards = {}
local GenderFilter = "Neutral"

local function AddCard(plr)
	if PlayerCards[plr] then return end
	local card = UI.CardTemplate:Clone()
	card.Name = plr.Name
	card.Visible = true
	PlayerCards[plr] = card

	local img = card:FindFirstChildOfClass("ImageLabel")
	if img then
		local ok, url = pcall(Svc.Players.GetUserThumbnailAsync, Svc.Players, plr.UserId, Enum.ThumbnailType.HeadShot, Enum.ThumbnailSize.Size420x420)
		if ok then img.Image = url end
	end

	local dn = card:FindFirstChild("DisplayName")
	local un = card:FindFirstChild("UserName")
	if dn then dn.Text = plr.DisplayName end
	if un then un.Text = plr.Name end

	card.Parent = UI.PlayersList
	card.Activated:Connect(function()
		UI.FT.Visible = true
		TargetPlayer = plr
		UI.TargetNameLabel.Text = plr.Name .. " (" .. plr.DisplayName .. ")"
	end)
end




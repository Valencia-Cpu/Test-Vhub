local cachedList = {}

local function HttpGet()
	local ok, res = pcall(function()
		return request({ Url = BASE_URL, Method = "GET" })
	end)
	if not ok or not res or res.StatusCode ~= 200 then return nil end
	local ok2, data = pcall(function() return HttpService:JSONDecode(res.Body) end)
	if ok2 and type(data) == "table" then
		cachedList = data
		return data
	end
	return nil
end


local function HttpSet(data)
	cachedList = data.executores or {}
	pcall(function()
		request({
			Url = BASE_URL,
			Method = "PUT",
			Headers = { ["Content-Type"] = "application/json" },
			Body = HttpService:JSONEncode(cachedList)
		})
	end)
end

local function CreateTag(char, data)
	local head = char:WaitForChild("Head")
	local old = head:FindFirstChild("PlayerTag")
	if old then old:Destroy() end

	local billboard = Instance.new("BillboardGui")
	billboard.Name = "PlayerTag"
	billboard.Size = UDim2.new(0, 120, 0, 30)
	billboard.StudsOffset = Vector3.new(0, 1.5, 0)
	billboard.MaxDistance = 45
	billboard.AlwaysOnTop = false
	billboard.Adornee = head
	billboard.Parent = head

	local label = Instance.new("TextLabel")
	label.Size = UDim2.new(1, 0, 1, 0)
	label.BackgroundTransparency = 1
	label.TextScaled = true
	label.Font = data.Font or Enum.Font.FredokaOne
	label.TextColor3 = data.Color or Color3.new(1,1,1)
	label.TextStrokeTransparency = 1
	label.Text = data.Text or "V"
	label.Parent = billboard

	local stroke = Instance.new("UIStroke")
	stroke.Color = data.StrokeColor or Color3.new(0,0,0)
	stroke.Thickness = data.StrokeThickness or 1.5
	stroke.Transparency = 0
	stroke.ApplyStrokeMode = Enum.ApplyStrokeMode.Contextual
	stroke.Parent = label

	if data.Gradient and data.GradientColors then
		local grad = Instance.new("UIGradient")
		local keypoints = {}
		for i, color in ipairs(data.GradientColors) do
			local t = (i-1)/(#data.GradientColors-1)
			table.insert(keypoints, ColorSequenceKeypoint.new(t, color))
		end
		grad.Color = ColorSequence.new(keypoints)
		grad.Parent = label

		if data.Animated then
			task.spawn(function()
				local offset = 0
				local dir = 1
				while grad and grad.Parent do
					if data.AnimationStyle == "Scroll" then
						offset = offset + 0.01
						grad.Offset = Vector2.new(offset, 0)
					elseif data.AnimationStyle == "Bounce" then
						offset = offset + 0.01 * dir
						if offset > 1 then dir = -1 end
						if offset < -1 then dir = 1 end
						grad.Offset = Vector2.new(offset, 0)
					elseif data.AnimationStyle == "Rotate" then
						grad.Rotation = grad.Rotation + 2
					elseif data.AnimationStyle == "Rainbow" then
						local t = tick() * 0.5
						grad.Color = ColorSequence.new({
							ColorSequenceKeypoint.new(0, Color3.fromHSV(t % 1, 1, 1)),
							ColorSequenceKeypoint.new(1, Color3.fromHSV((t + 0.5) % 1, 1, 1))
						})
					end
					task.wait(0.02)
				end
			end)
		end
	end

	-- animação Replicate (independente do gradient)
	if data.Animated and data.AnimationStyle == "Replicate" then
		task.spawn(function()
			while label and label.Parent do
				local particle = Instance.new("TextLabel")
				particle.Size = label.Size
				particle.Position = label.Position
				particle.AnchorPoint = label.AnchorPoint
				particle.BackgroundTransparency = 1
				particle.TextScaled = true
				particle.Font = label.Font
				particle.TextColor3 = label.TextColor3
				particle.TextStrokeTransparency = 1
				particle.Text = label.Text
				particle.ZIndex = label.ZIndex - 1
				particle.Parent = billboard

				local offsetX = math.random(-40, 40)
				local offsetY = math.random(-40, 40)

				Svc.TweenSvc:Create(
					particle,
					TweenInfo.new(0.8, Enum.EasingStyle.Quad, Enum.EasingDirection.Out),
					{
						Position = UDim2.new(
							particle.Position.X.Scale,
							particle.Position.X.Offset + offsetX,
							particle.Position.Y.Scale,
							particle.Position.Y.Offset + offsetY
						),
						TextTransparency = 1
					}
				):Play()

				task.delay(0.8, function()
					particle:Destroy()
				end)

				task.wait(0.05)
			end
		end)
	end
end


local function GetExecutorList()
	local data = HttpGet()
	return (data and type(data.executores) == "table") and data.executores or {}
end

local function IsExecutor(userId)
	for _, entry in ipairs(GetExecutorList()) do
		if entry.userId == userId then return true end
	end
	return false
end

local function AddToList()
	local lista = GetExecutorList()
	for _, entry in ipairs(lista) do
		if entry.userId == LP.UserId then return end -- já está
	end
	table.insert(lista, { userId = LP.UserId, name = LP.Name, lastSeen = os.time() })
	HttpSet({ executores = lista })
end

local function RemoveFromList()
	local lista = GetExecutorList()
	local nova  = {}
	for _, entry in ipairs(lista) do
		if entry.userId ~= LP.UserId then table.insert(nova, entry) end
	end
	HttpSet({ executores = nova })
end

local function UpdateLastSeen()
	local lista = GetExecutorList()
	for _, entry in ipairs(lista) do
		if entry.userId == LP.UserId then entry.lastSeen = os.time() end
	end
	HttpSet({ executores = lista })
end

local function LimparListaVelha()
	local lista = GetExecutorList()
	local nova, agora = {}, os.time()
	for _, entry in ipairs(lista) do
		if (agora - (entry.lastSeen or 0)) < 300 then
			table.insert(nova, entry)
		end
	end
	if #nova ~= #lista then HttpSet({ executores = nova }) end
	return nova
end




local function SaveConfig()
	local data = {
		Keys = {},
		State = {},
		CFG = {
			WalkSpeed = CFG.WalkSpeed.Default,
			Spin = CFG.Spin
		}
	}

	for k, v in pairs(DefaultKeys) do
		data.Keys[k] = v.Name
	end

	for k, v in pairs(State) do
		data.State[k] = v
	end

	pcall(function()
		if writefile then
			writefile(FILE_NAME, HttpService:JSONEncode(data))
		end
	end)
end


local function LoadConfig()
	local success, data = pcall(function()
		if not isfile or not readfile then return nil end
		if not isfile(FILE_NAME) then return nil end

		return HttpService:JSONDecode(readfile(FILE_NAME))
	end)

	if not success or not data then return end


	if data.Keys then
		for k, v in pairs(data.Keys) do
			if Enum.KeyCode[v] then
				DefaultKeys[k] = Enum.KeyCode[v]
			end
		end
	end

	if data.State then
		for k, v in pairs(data.State) do
			if State[k] ~= nil then
				State[k] = v
			end
		end
	end


	if data.CFG then
		if data.CFG.WalkSpeed then
			CFG.WalkSpeed.Default = data.CFG.WalkSpeed
		end

		if data.CFG.Spin then
			CFG.Spin = data.CFG.Spin
		end
	end
end


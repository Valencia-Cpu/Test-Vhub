local MAX_VELOCITY = 10
local Connection
local LastCFrame

local FORCE_CLASSES = {
	BodyVelocity = true,

}

local function RemoveIfForce(obj)
	if FORCE_CLASSES[obj.ClassName] then
		obj:Destroy()
	end
end


local function AntiFling(Char)

	if Connection then
		Connection:Disconnect()
	end

	local Root = Char:WaitForChild("HumanoidRootPart")
	local Hum = Char:WaitForChild("Humanoid")

	LastCFrame = Root.CFrame


	Char.DescendantAdded:Connect(function(obj)
		if not State.AntiFling then return end

		RemoveIfForce(obj)
	end)

	Connection = RunService.Heartbeat:Connect(function()
		if not Char.Parent then return end
		if not Root.Parent then return end
		if not State.AntiFling then return end

		local vel = Root.AssemblyLinearVelocity


		if vel.Magnitude > MAX_VELOCITY then
			Root.CFrame = LastCFrame
			Root.AssemblyLinearVelocity = Vector3.zero
			Root.AssemblyAngularVelocity = Vector3.zero
		else
			LastCFrame = Root.CFrame
		end


		for _, v in ipairs(Char:GetDescendants()) do
			RemoveIfForce(v)

			if v:IsA("BasePart") then
				if v.AssemblyLinearVelocity.Magnitude > MAX_VELOCITY then
					v.AssemblyLinearVelocity = Vector3.zero
					v.AssemblyAngularVelocity = Vector3.zero
				end
			end
		end


		if Hum.Sit then
			Hum.Sit = false
			Hum:ChangeState(Enum.HumanoidStateType.GettingUp)
		end


		local state = Hum:GetState()

		if state == Enum.HumanoidStateType.Physics
			or state == Enum.HumanoidStateType.Ragdoll then

			Hum:ChangeState(Enum.HumanoidStateType.GettingUp)
		end
	end)
end 


local function AntiKnockback(Char)

	local Hum =Char:WaitForChild("Humanoid")
	local Root = Char:WaitForChild("HumanoidRootPart")
	Char.DescendantAdded:Connect(function(obj)
		if not State.AntiGlove then return end

		if obj:IsA("BodyVelocity")
			or obj:IsA("BodyAngularVelocity")
			or obj:IsA("BodyForce")
			or obj:IsA("VectorForce")
			or obj:IsA("LinearVelocity")
			or obj:IsA("AngularVelocity") then
			if Char:FindFirstChild("Fly") then return end

			if Hum.Sit then
				Hum.Sit = false
			end

			Root.AssemblyLinearVelocity = Vector3.zero
			Root.AssemblyAngularVelocity = Vector3.zero

			task.defer(function()
				if not obj or not obj.Parent then return end


				Root.AssemblyLinearVelocity = Vector3.zero
				Root.AssemblyAngularVelocity = Vector3.zero

				if Hum.Sit then
					Hum.Sit = false
				end

				obj:Destroy()


				Root.AssemblyLinearVelocity = Vector3.zero
				Root.AssemblyAngularVelocity = Vector3.zero
				if Hum.Sit then
					Hum.Sit = false
				end


			end)
			if Hum.Sit then
				Hum.Sit = false
			end
		end
		if Hum.Sit then
			Hum.Sit = false
		end
	end)


	Hum.StateChanged:Connect(function(_, new)

		if not State.AntiGlove then return end
		if Hum.Sit then
			Hum.Sit = false
		end
		if new == Enum.HumanoidStateType.Physics
			or new == Enum.HumanoidStateType.Ragdoll then

			Hum:ChangeState(Enum.HumanoidStateType.GettingUp)
		end
	end)
end


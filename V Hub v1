end


local function StartBackpack(target)
	if not target then return end

	local function AttachToCharacter(char)
		if not char then return end

		local root = GetRoot(char)
		local myRoot = GetRoot(Char)

		if not root or not myRoot then return end

		local hum = GetHum()
		if hum then
			hum.AutoRotate = false
			hum.Sit = true
		end


		if BackpackConn then
			BackpackConn:Disconnect()
		end

		BackpackConn = game:GetService("RunService").Heartbeat:Connect(function()
			if not BackpackState then return end

			if not root or not root.Parent then return end
			if not myRoot or not myRoot.Parent then return end

			local backCF = root.CFrame * CFrame.new(0, 0, 3)

			myRoot.CFrame = CFrame.new(backCF.Position, root.Position)
		end)


		local humTarget = char:FindFirstChildOfClass("Humanoid")
		if humTarget then
			humTarget.Died:Connect(function()
				if BackpackState then
					target.CharacterAdded:Wait()

					if BackpackState then
						StartBackpack(target)
					end
				end
			end)
		end
	end

	BackpackState = true
	CurrentTarget = target
	UI.BtnBackPack.Text = "Unbackpack"

	AttachToCharacter(target.Character)

	target.CharacterAdded:Connect(function(newChar)
		if BackpackState and CurrentTarget == target then
			task.wait(0.2)
			AttachToCharacter(newChar)
		end
	end)
end





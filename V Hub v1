-- ESP

local ESPConns = {}

local function EspAdd(plr)
	if plr == LP or ESPConns[plr] then return end

	local frame = New("Frame", {
		Size = UDim2.new(0, 100, 0, 60),
		BackgroundTransparency = 1,
		AnchorPoint = Vector2.new(0.5, 0.5)
	}, UI.EspGui)
	local img :ImageButton


	img = New("ImageButton", {
		Size = UDim2.new(0, 40, 0, 40),
		Position = UDim2.new(0.5, 0, 0, 0),
		AnchorPoint = Vector2.new(0.5, 0),
		BackgroundTransparency = 1,
	}, frame)

	New("UICorner", {
		CornerRadius = UDim.new(1,0)
	}, img)

	New("UIStroke", {
		Color = Color3.new(1,1,1),
		Thickness = 1
	}, img)

	if  not State.HideImage then
		img.Visible = false
	end


	local lbl = New("TextLabel", {
		Size = UDim2.new(1, 0, 0, 18),
		Position = UDim2.new(0, 0, 1, -18),
		BackgroundTransparency = 1,
		TextScaled = false,
		TextSize = 14,
		Font = Enum.Font.SourceSansBold,
		TextColor3 = Color3.new(0, 0, 0),
		TextStrokeTransparency = 0,
		Text = "",
	}, frame)

	New("UIStroke", {
		Color = Color3.new(0.580392, 0.580392, 0.580392),
		Thickness = 0.8
	}, lbl)

	-- foto do player
	if img then
		task.spawn(function()
			local content, _ = Svc.Players:GetUserThumbnailAsync(plr.UserId, Enum.ThumbnailType.HeadShot, Enum.ThumbnailSize.Size100x100)
			img.Image = content
		end)
	end


	-- click = teleport
	if img then
		img.MouseButton1Click:Connect(function()
			if plr.Character and Char then
				local targetRoot = plr.Character:FindFirstChild("HumanoidRootPart")
				local myRoot = Char:FindFirstChild("HumanoidRootPart")

				if targetRoot and myRoot then
					Char:PivotTo(targetRoot.CFrame)
				end
			end
		end)
	end


	local conn = Svc.Run.RenderStepped:Connect(function()
		if not plr.Character then frame.Visible = false return end

		local head = plr.Character:FindFirstChild("Head")
		if not head then frame.Visible = false return end

		local pos, onScreen = Camera:WorldToViewportPoint(head.Position + Vector3.new(0, 3, 0))

		if onScreen then
			frame.Visible = true
			frame.Position = UDim2.new(0, pos.X, 0, pos.Y)
			lbl.Text = plr.DisplayName .. " (" .. plr.Name .. ")"
		else
			frame.Visible = false
		end
	end)

	ESPConns[plr] = {
		conn = conn,
		gui = frame
	}
end

local function EspRemove(plr)
	local d = ESPConns[plr]
	if not d then return end

	if d.conn then d.conn:Disconnect() end
	if d.gui then d.gui:Destroy() end

	ESPConns[plr] = nil
end

local function EspAll(enable)
	if enable then
		for _, p in Svc.Players:GetPlayers() do
			if p ~= LP then
				EspAdd(p)
			end
		end
	else
		for plr in pairs(ESPConns) do
			EspRemove(plr)
		end
		table.clear(ESPConns)
	end
end


